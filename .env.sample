POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=graphlm

DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}
ASYNC_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/${POSTGRES_DB}

ENVIRONMENT=development
PORT=4000
HOST=127.0.0.1
CLIENT_URL=http://localhost:5173
BASE_URL=http://localhost:4000/

CORS_ORIGIN=*

MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=your_mailtrap_user
MAILTRAP_SMTP_PASS=your_mailtrap_password
MAILTRAP_SENDEREMAIL=noreply@example.com
MAIL_FROM_NAME=GraphLM Team

ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY_HOURS=15
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY_DAYS=7

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5.4-nano

GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

MODEL_MAX_TOKENS=128000
CONTEXT_SAFE_RATIO=0.75
CONTEXT_RESERVED_FOR_RAG=15000
CONTEXT_RESERVED_FOR_RESPONSE=5000
CONTEXT_KEEP_RECENT=6
SEMANTIC_TOP_K=15
MIN_EMBED_CHARS=20
SYSTEM_PROMPT_BUDGET=1000
COMPACTION_THRESHOLD=0.85
COMPACTION_TARGET_RATIO=0.50

MEM0_API_KEY=your_mem0_api_key_here